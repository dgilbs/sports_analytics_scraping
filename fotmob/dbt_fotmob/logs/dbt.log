        )
    end
 as duels_won_pct,
    -- discipline
    sum(fouls_committed)                            as fouls_committed,
    sum(was_fouled)                                 as was_fouled,
    round(avg(avg_player_rating)::numeric, 2)       as avg_player_rating
from base
group by 1, 2, 3
  );
