  create view "neondb"."fotmob"."draft_consistency__dbt_tmp"
    
    
  as (
    -- Match-by-match consistency analysis for draft prep.
-- Shows how reliable a player's scoring is across different contexts:
-- opponent strength, home/away, and recent form.
with match_pts as (
    select
        p.player_id,
        p.player_name,
        p.draft_position,
        p.match_date,
        p.team_name,
        p.opponent_name,
        p.side,
        p.minutes_played,
        p.total_points,
        -- rolling last 5 matches (ordered by date)
        row_number() over (
            partition by p.player_id
            order by p.match_date desc
        )                                                           as match_recency
    from "neondb"."fotmob"."fantasy_match_points" p
    where p.draft_position is not null
      and p.minutes_played > 0
),

-- opponent strength: avg goals conceded per match in 2025
-- (more goals conceded = weaker defense = better for attackers,
--  more goals scored against = harder for GK/DEF clean sheets)
opponent_strength as (
    select
        team_name,
        round(avg(team_goals_conceded)::numeric, 2)     as avg_goals_conceded,
        round(avg(total_points)::numeric, 2)            as avg_pts_allowed
    from "neondb"."fotmob"."fantasy_match_points"
    where draft_position is not null
      and minutes_played > 0
    group by 1
),

-- per-player aggregates split by context
player_splits as (
    select
        m.player_id,
        m.player_name,
        m.draft_position,

        -- overall
        count(*)                                                    as matches_played,
        round(avg(m.total_points)::numeric, 2)                     as avg_pts,

        -- recent form (last 5 matches)
        round(avg(case when m.match_recency <= 5
            then m.total_points end)::numeric, 2)                  as avg_pts_last5,

        -- home vs away
        round(avg(case when m.side = 'home'
            then m.total_points end)::numeric, 2)                  as avg_pts_home,
        round(avg(case when m.side = 'away'
            then m.total_points end)::numeric, 2)                  as avg_pts_away,

        -- vs strong opponents (above-average defense)
        round(avg(
            case when os.avg_goals_conceded <
                (select avg(avg_goals_conceded) from opponent_strength)
            then m.total_points end
        )::numeric, 2)                                             as avg_pts_vs_strong,

        -- vs weak opponents (below-average defense)
        round(avg(
            case when os.avg_goals_conceded >=
                (select avg(avg_goals_conceded) from opponent_strength)
            then m.total_points end
        )::numeric, 2)                                             as avg_pts_vs_weak,

        -- scoring bands
        sum(case when m.total_points >= 15  then 1 else 0 end)     as matches_15_plus,
        sum(case when m.total_points >= 10
                  and m.total_points < 15  then 1 else 0 end)      as matches_10_to_15,
        sum(case when m.total_points >= 5
                  and m.total_points < 10  then 1 else 0 end)      as matches_5_to_10,
        sum(case when m.total_points >= 0
                  and m.total_points < 5   then 1 else 0 end)      as matches_0_to_5,
        sum(case when m.total_points < 0   then 1 else 0 end)      as matches_negative,

        -- trend: recent form vs season avg (positive = improving)
        round((
            avg(case when m.match_recency <= 5 then m.total_points end) -
            avg(m.total_points)
        )::numeric, 2)                                             as form_trend

    from match_pts m
    left join opponent_strength os on m.opponent_name = os.team_name
    group by 1, 2, 3
)

select
    ps.draft_position,
    ps.player_name,
    ps.matches_played,
    ps.avg_pts,
    ps.avg_pts_last5,
    ps.form_trend,
    ps.avg_pts_home,
    ps.avg_pts_away,
    round((ps.avg_pts_home - ps.avg_pts_away)::numeric, 2)         as home_away_diff,
    ps.avg_pts_vs_strong,
    ps.avg_pts_vs_weak,
    round((ps.avg_pts_vs_weak - ps.avg_pts_vs_strong)::numeric, 2) as soft_schedule_reliance,
    ps.matches_15_plus,
    ps.matches_10_to_15,
    ps.matches_5_to_10,
    ps.matches_0_to_5,
    ps.matches_negative,
    rank() over (
        partition by ps.draft_position
        order by ps.avg_pts_last5 desc nulls last
    )                                                               as form_rank
from player_splits ps
order by ps.draft_position, form_rank
  );
