        then null
        else round(
            cast(sum(accurate_long_balls_succeeded) as decimal) / cast(sum(accurate_long_balls_attempted) as decimal),
            4
        )
    end
 as accurate_long_balls_pct,
    -- dribbles
    sum(successful_dribbles_succeeded) as successful_dribbles,
